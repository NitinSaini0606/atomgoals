generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  employeeCode String?  @unique
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(EMPLOYEE)
  managerId    Int?
  manager      User?    @relation("ManagerReports", fields: [managerId], references: [id])
  reports      User[]   @relation("ManagerReports")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  goals            Goal[]        @relation("GoalOwner")
  goalSheets       GoalSheet[]
  managedGoals     Goal[]        @relation("GoalManager")
  achievements     Achievement[]
  checkIns         CheckIn[]      @relation("EmployeeCheckIns")
  managerCheckIns  CheckIn[]      @relation("ManagerCheckIns")
  auditLogs        AuditLog[]
  ownedSharedGoals SharedGoal[]  @relation("SharedGoalOwner")
  sharedGoals      SharedGoal[]  @relation("SharedGoalMembers")
}

model GoalCycle {
  id        Int             @id @default(autoincrement())
  name      String
  quarter   String
  year      Int
  startDate DateTime
  endDate   DateTime
  status    GoalCycleStatus @default(DRAFT)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  goals       Goal[]
  goalSheets  GoalSheet[]
  checkIns    CheckIn[]
  sharedGoals SharedGoal[]

  @@unique([year, quarter])
}

model GoalSheet {
  id              Int             @id @default(autoincrement())
  ownerId         Int
  owner           User            @relation(fields: [ownerId], references: [id])
  cycleId         Int
  cycle           GoalCycle       @relation(fields: [cycleId], references: [id])
  status          GoalSheetStatus @default(DRAFT)
  managerFeedback String?
  submittedAt     DateTime?
  reviewedAt      DateTime?
  approvedAt      DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  goals Goal[]

  @@unique([ownerId, cycleId])
  @@index([cycleId])
}

model Goal {
  id                Int        @id @default(autoincrement())
  thrustArea        String
  title             String
  description       String?
  uomType           UomType    @default(NUMERIC)
  scoreDirection    ScoreDirection @default(MIN)
  targetValue       String?
  deadline          DateTime?
  plannedMetric     String?
  actualMetric      String?
  plannedValue      Decimal?   @db.Decimal(10, 2)
  actualValue       Decimal?   @db.Decimal(10, 2)
  weight            Int        @default(0)
  completionPercent Int        @default(0)
  status            GoalStatus @default(DRAFT)
  ownerId           Int
  owner             User       @relation("GoalOwner", fields: [ownerId], references: [id])
  managerId         Int?
  manager           User?      @relation("GoalManager", fields: [managerId], references: [id])
  cycleId           Int
  cycle             GoalCycle  @relation(fields: [cycleId], references: [id])
  goalSheetId       Int
  goalSheet         GoalSheet  @relation(fields: [goalSheetId], references: [id])
  sharedGoalId      Int?
  sharedGoal        SharedGoal? @relation(fields: [sharedGoalId], references: [id])
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  achievements Achievement[]

  @@index([ownerId])
  @@index([managerId])
  @@index([cycleId])
  @@index([goalSheetId])
  @@index([sharedGoalId])
}

model Achievement {
  id             Int               @id @default(autoincrement())
  goalId         Int
  goal           Goal              @relation(fields: [goalId], references: [id])
  userId         Int
  user           User              @relation(fields: [userId], references: [id])
  quarter        String
  actualValue    String?
  status         AchievementStatus @default(NOT_STARTED)
  completionDate DateTime?
  employeeNote   String?
  progressScore  Float             @default(0)
  weightedScore  Float             @default(0)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@unique([goalId, quarter])
  @@index([goalId])
  @@index([userId])
  @@index([quarter])
}

model CheckIn {
  id          Int           @id @default(autoincrement())
  userId      Int
  user        User          @relation("EmployeeCheckIns", fields: [userId], references: [id])
  managerId   Int
  manager     User          @relation("ManagerCheckIns", fields: [managerId], references: [id])
  quarter     String
  comment     String?
  status      CheckInStatus @default(DRAFT)
  completedAt DateTime?
  cycleId     Int?
  cycle       GoalCycle?    @relation(fields: [cycleId], references: [id])
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@unique([userId, managerId, quarter])
  @@index([userId])
  @@index([managerId])
  @@index([quarter])
  @@index([cycleId])
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  actorId    Int?
  actor      User?    @relation(fields: [actorId], references: [id])
  action     String
  entityType String
  entityId   Int?
  details    Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([actorId])
  @@index([entityType, entityId])
}

model SharedGoal {
  id          Int              @id @default(autoincrement())
  title       String
  description String?
  ownerId     Int
  owner       User             @relation("SharedGoalOwner", fields: [ownerId], references: [id])
  cycleId     Int
  cycle       GoalCycle        @relation(fields: [cycleId], references: [id])
  status      SharedGoalStatus @default(ACTIVE)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  goals   Goal[]
  members User[] @relation("SharedGoalMembers")

  @@index([ownerId])
  @@index([cycleId])
}

enum UserRole {
  EMPLOYEE
  MANAGER
  ADMIN
}

enum GoalCycleStatus {
  DRAFT
  ACTIVE
  CLOSED
}

enum GoalStatus {
  DRAFT
  SUBMITTED
  L1_APPROVED
  REVISION_REQUESTED
  APPROVED_LOCKED
  IN_PROGRESS
  COMPLETED
  CLOSED
}

enum GoalSheetStatus {
  DRAFT
  SUBMITTED
  REVISION_REQUESTED
  APPROVED_LOCKED
}

enum UomType {
  NUMERIC
  PERCENTAGE
  TIMELINE
  ZERO_BASED
}

enum ScoreDirection {
  MIN
  MAX
  NONE
}

enum CheckInStatus {
  DRAFT
  SUBMITTED
  REVIEWED
  COMPLETED
}

enum AchievementStatus {
  NOT_STARTED
  ON_TRACK
  COMPLETED
}

enum SharedGoalStatus {
  ACTIVE
  ARCHIVED
}
